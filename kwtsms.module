<?php

/**
 * @file
 * Primary module file for kwtSMS.
 *
 * Provides SMS gateway integration with kwtsms.com for Drupal.
 * Hooks are kept minimal; business logic lives in services.
 *
 * Related files:
 *   - src/Service/KwtsmsGateway.php (API client)
 *   - kwtsms.routing.yml (admin routes)
 *   - kwtsms.services.yml (service definitions)
 */

declare(strict_types=1);

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function kwtsms_help(string $route_name, RouteMatchInterface $route_match): string {
  if ($route_name === 'help.page.kwtsms') {
    return '<p>' . t('kwtSMS provides SMS gateway integration with kwtsms.com. Configure the gateway at <a href=":url">kwtSMS settings</a>.', [
      ':url' => \Drupal\Core\Url::fromRoute('kwtsms.dashboard')->toString(),
    ]) . '</p>';
  }
  return '';
}

/**
 * Implements hook_token_info().
 */
function kwtsms_token_info(): array {
  $types['kwtsms'] = [
    'name' => t('kwtSMS'),
    'description' => t('Tokens related to kwtSMS.'),
  ];
  $tokens['kwtsms']['otp-code'] = [
    'name' => t('OTP Code'),
    'description' => t('The one-time password code.'),
  ];
  $tokens['kwtsms']['sender-id'] = [
    'name' => t('Sender ID'),
    'description' => t('The active kwtSMS sender ID.'),
  ];
  $tokens['kwtsms']['balance'] = [
    'name' => t('Balance'),
    'description' => t('Current kwtSMS account balance.'),
  ];
  return ['types' => $types, 'tokens' => $tokens];
}

/**
 * Implements hook_tokens().
 */
function kwtsms_tokens(string $type, array $tokens, array $data, array $options): array {
  $replacements = [];
  if ($type === 'kwtsms') {
    foreach ($tokens as $name => $original) {
      switch ($name) {
        case 'sender-id':
          $replacements[$original] = \Drupal::config('kwtsms.settings')->get('sender_id') ?: 'KWT-SMS';
          break;
        case 'balance':
          $gateway = \Drupal::service('kwtsms.gateway');
          $balance = $gateway->getCachedValue('balance');
          $replacements[$original] = $balance['available'] ?? '0';
          break;
        case 'otp-code':
          $replacements[$original] = $data['kwtsms_otp_code'] ?? '[OTP]';
          break;
      }
    }
  }
  return $replacements;
}
